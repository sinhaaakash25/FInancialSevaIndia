# Copy this file to .env and fill in your own values. Never commit .env.

# Free access key from https://web3forms.com — lets the Contact form and
# Bindu chatbot email leads to you with NO backend server required.
VITE_WEB3FORMS_KEY=

# Where leads should land if Web3Forms isn't configured (mailto fallback).
VITE_LEAD_EMAIL=you@example.com
